<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Emotion-Based Book Reader</title>
<style>
  body {
    background: url("file:///C:/Users/MGB/Desktop/nhek/IMAGES/download%20(4).jpg") no-repeat center center / contain;
    margin: 0;
    font-family: Arial, sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px;
  }

  h2 {
    font-family: 'Brush Script MT', cursive;
    color: #FFC0CB;
    font-size: 3em;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
  }

  .library {
     padding: 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    justify-items: center;
    height: calc(100vh - 80px);
    overflow-y: auto;
  }

  /* BOOKS: make them perfect squares */
  .book {
    width: 250px;
    height: 300px; /* ensures it's square */
    margin: 10px;
    cursor: pointer;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
    background: #fff;
  }

  .book:hover {
    transform: scale(1.05);
  }

  /* Make image fit perfectly inside the square */
  .book img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* crops the image nicely to fit the square */
    border-radius: 8px;
  }

  /* Bottom navigation */
  .nav {
    display: flex;
    justify-content: space-around;
    background: #fff;
    padding: 10px 0;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
    position: fixed;
    bottom: 0;
    width: 100%;
  }

  .nav button {
    background: #ffd700;
    border: none;
    padding: 10px 20px;
    border-radius: 20px;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.3s;
  }

  .nav button:hover {
    background: #ffc107;
  }

  /* ICON BUTTONS */
  .icon-btn {
    position: absolute;
    top: 20px;
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: #f7a1c4;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 22px;
    cursor: pointer;
  }

  .back {
    left: 20px;
  }

  .home {
    right: 20px;
  }


</style>
</head>
<body>
<div class="icon-btn back" onclick="history.back()">â¬…</div>
